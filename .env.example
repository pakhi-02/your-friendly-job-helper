CANDIDATE_NAME=Your Name
CANDIDATE_EMAIL=you@example.com
CANDIDATE_PHONE=+1-000-000-0000
CANDIDATE_LOCATION=City, Country
CANDIDATE_LINKEDIN=https://linkedin.com/in/your-profile
CANDIDATE_PORTFOLIO=https://your-portfolio.dev

OUTPUT_DIR=application_docs
TOP_KEYWORDS=20
MIN_KEYWORD_LENGTH=3
MAX_INPUT_CHARS=12000

# Web server / hosting. Set APP_PASSWORD before exposing the app publicly;
# leave it empty for local use to disable the login prompt.
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false
APP_USERNAME=admin
APP_PASSWORD=

# HTTPS via the Caddy reverse proxy. Use "localhost" for local testing, or your
# real domain (DNS pointed at the host) for a hosted deployment.
DOMAIN=localhost
ACME_EMAIL=you@example.com

USE_LLM=true
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.3
COVER_LETTER_TONE=formal
COVER_LETTER_LENGTH=medium

# --- Auto-apply (browser automation) ---
# Leave AUTO_SUBMIT=false until you trust the output. false = fill + screenshot
# + pause for you to review; true = also click the submit button automatically.
AUTO_SUBMIT=false
APPLY_HEADLESS=false
APPLY_RESUME_FILE=resume.pdf
APPLY_SCREENSHOT_DIR=application_docs/screenshots
APPLY_SLOW_MO_MS=150

# Canned answers used verbatim for common required questions (so the small local
# model never guesses on legally meaningful fields). Edit to match your situation.
APPLY_WORK_AUTHORIZED=Yes
APPLY_NEEDS_SPONSORSHIP=No
APPLY_GENDER=Decline To Self Identify
APPLY_RACE=Decline To Self Identify
APPLY_VETERAN=I don't wish to answer
APPLY_DISABILITY=I don't wish to answer
APPLY_SALARY_EXPECTATION=
APPLY_START_DATE=Immediately
